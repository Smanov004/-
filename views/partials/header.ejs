<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>ИС Автосалона</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
</head>
<body>
    <div class="app-layout">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>Автосалон</h2>
                <p>Система управления</p>
            </div>
            <nav class="sidebar-nav">
                <a href="/dashboard" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'dashboard' ? 'active' : '' %>">
                    <span>Главная панель</span>
                </a>
                <a href="/cars" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'cars' ? 'active' : '' %>">
                    <span>Автомобили</span>
                </a>
                <a href="/inspections" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'inspections' ? 'active' : '' %>">
                    <span>Акты осмотра</span>
                </a>
                <a href="/test-drives" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'test-drives' ? 'active' : '' %>">
                    <span>Тест-драйвы</span>
                </a>
                <a href="/sales" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'sales' ? 'active' : '' %>">
                    <span>Продажи</span>
                </a>
                <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                <a href="/reports" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'reports' ? 'active' : '' %>">
                    <span>Отчёты</span>
                </a>
                <% } %>
                <a href="/clients" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'clients' ? 'active' : '' %>">
                    <span>Клиенты</span>
                </a>
                <a href="/warranty" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'warranty' ? 'active' : '' %>">
                    <span>Гарантийное обслуживание</span>
                </a>
                <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                <a href="/users" class="sidebar-nav-item <%= typeof currentPage !== 'undefined' && currentPage === 'users' ? 'active' : '' %>">
                    <span>Пользователи</span>
                </a>
                <% } %>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="main-content-wrapper">
            <!-- Header -->
            <header class="header">
                <h1 class="header-title"><%= typeof title !== 'undefined' ? title : 'Главная панель' %></h1>
                <div class="header-right">
                    <div class="notification-wrapper">
                        <button class="notification-icon" id="notificationToggle" type="button" aria-expanded="false" aria-controls="notificationDropdown" title="Уведомления">
                            Уведомления
                            <span class="notification-badge" id="notificationCount" style="display: none;">0</span>
                        </button>
                        <div class="notification-dropdown" id="notificationDropdown" aria-hidden="true">
                            <div class="notification-dropdown-header">
                                <span>Уведомления</span>
                                <button class="btn-link" id="notificationClear" type="button">Очистить</button>
                            </div>
                            <div class="notification-list" id="notificationList">
                                <div class="notification-empty">Нет новых уведомлений</div>
                            </div>
                        </div>
                    </div>
                    <% if (typeof user !== 'undefined' && user) { %>
                    <div class="user-profile">
                        <div class="user-avatar"><%= user.fullName.charAt(0).toUpperCase() %></div>
                        <div class="user-info">
                            <div class="user-name"><%= user.fullName %></div>
                            <div class="user-role">
                                <%= user.role === 'admin' ? 'Администратор' : user.role === 'supervisor' ? 'Руководитель' : 'Менеджер' %>
                            </div>
                        </div>
                    </div>
                    <form method="POST" action="/logout" style="display: inline;">
                        <button type="submit" class="btn btn-sm btn-secondary">Выход</button>
                    </form>
                    <% } %>
                </div>
            </header>

            <!-- Content Area -->
            <main class="content-area">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-error">
                        <strong>Ошибка:</strong> <%= error %>
                    </div>
                <% } %>
