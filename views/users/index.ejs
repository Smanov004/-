<%- include('../partials/header', { title: 'Управление пользователями', currentPage: 'users', user: typeof user !== 'undefined' ? user : null }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>Пользователи системы</h2>
            <a href="/users/new" class="btn btn-primary">Добавить пользователя</a>
        </div>
        
        <% if (users && users.length > 0) { %>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Логин</th>
                            <th>ФИО</th>
                            <th>Роль</th>
                            <th>Email</th>
                            <th>Дата создания</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u => { %>
                            <tr>
                                <td><%= u.id %></td>
                                <td><strong><%= u.username %></strong></td>
                                <td><%= u.full_name %></td>
                                <td>
                                    <span class="badge badge-<%= u.role === 'admin' ? 'danger' : u.role === 'supervisor' ? 'info' : 'success' %>">
                                        <%= u.role === 'admin' ? 'Администратор' : u.role === 'supervisor' ? 'Руководитель' : 'Менеджер' %>
                                    </span>
                                </td>
                                <td><%= u.email || '-' %></td>
                                <td><%= new Date(u.created_at).toLocaleDateString('ru-RU') %></td>
                                <td>
                                    <% if (u.id !== user.id) { %>
                                        <form method="POST" action="/users/<%= u.id %>/delete" style="display: inline;" onsubmit="return confirm('Вы уверены, что хотите удалить этого пользователя?');">
                                            <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                        </form>
                                    <% } else { %>
                                        <span class="text-muted" style="font-size: 0.8rem;">(Вы)</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>Пользователи не найдены</p>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
