<%- include('../partials/header', { title: 'Клиенты', currentPage: 'clients', user: typeof user !== 'undefined' ? user : null }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>Управление клиентами</h2>
            <a href="/clients/new" class="btn btn-primary">Добавить клиента</a>
        </div>
        
        <% if (clients && clients.length > 0) { %>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Имя</th>
                            <th>Телефон</th>
                            <th>Email</th>
                            <th>Адрес</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% clients.forEach(client => { %>
                            <tr>
                                <td><%= client.id %></td>
                                <td><strong><%= client.name %></strong></td>
                                <td><%= client.phone %></td>
                                <td><%= client.email || '-' %></td>
                                <td><%= client.address || '-' %></td>
                                <td style="display: flex; gap: 0.5rem;">
                                    <a href="/clients/<%= client.id %>/edit" class="btn btn-sm btn-secondary">Редактировать</a>
                                    <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                                    <form method="POST" action="/clients/<%= client.id %>/delete" style="display: inline;" onsubmit="return confirm('Вы уверены, что хотите удалить этого клиента?');">
                                        <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                    </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>Клиенты не найдены</p>
                <a href="/clients/new" class="btn btn-primary">Добавить первого клиента</a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
