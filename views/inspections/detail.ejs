<%- include('../partials/header', { title: 'Детали акта осмотра', currentPage: 'inspections', user: typeof user !== 'undefined' ? user : null }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>Акт осмотра автомобиля №<%= inspection.id %></h2>
            <button onclick="window.print()" class="btn btn-secondary">Печать акта</button>
        </div>

        <div class="inspection-details">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">
                <div>
                    <h3>Информация об автомобиле</h3>
                    <p><strong>Марка и модель:</strong> <%= inspection.brand %> <%= inspection.model %></p>
                    <p><strong>Год выпуска:</strong> <%= inspection.year %></p>
                    <p><strong>Цвет:</strong> <%= inspection.color %></p>
                    <p><strong>Пробег:</strong> <%= inspection.mileage.toLocaleString('ru-RU') %> км</p>
                </div>
                <div>
                    <h3>Информация о приеме</h3>
                    <p><strong>Дата осмотра:</strong> <%= new Date(inspection.inspection_date).toLocaleDateString('ru-RU') %></p>
                    <p><strong>Инспектор:</strong> <%= inspection.inspector_name %></p>
                    <p><strong>Статус целостности:</strong> 
                        <% if (inspection.is_damaged) { %>
                            <span class="badge badge-danger">Поврежден</span>
                        <% } else { %>
                            <span class="badge badge-success">Целостность подтверждена</span>
                        <% } %>
                    </p>
                </div>
            </div>

            <div class="card" style="background: #f9fafb; border: none; padding: 1.5rem;">
                <h3>Результаты технического осмотра</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-top: 1rem;">
                    <div>
                        <small style="color: #666;">Кузов:</small>
                        <p><strong><%= inspection.body_condition %></strong></p>
                    </div>
                    <div>
                        <small style="color: #666;">Салон:</small>
                        <p><strong><%= inspection.interior_condition %></strong></p>
                    </div>
                    <div>
                        <small style="color: #666;">Двигатель:</small>
                        <p><strong><%= inspection.engine_condition %></strong></p>
                    </div>
                    <div>
                        <small style="color: #666;">Подвеска:</small>
                        <p><strong><%= inspection.suspension_condition %></strong></p>
                    </div>
                </div>
            </div>

            <% if (inspection.is_damaged) { %>
                <div style="margin-top: 2rem; padding: 1rem; border: 1px solid #ef4444; border-radius: 0.5rem; background: #fef2f2;">
                    <h3 style="color: #b91c1c;">Выявленные повреждения</h3>
                    <p><%= inspection.damage_details %></p>
                </div>
            <% } %>

            <% if (inspection.notes) { %>
                <div style="margin-top: 2rem;">
                    <h3>Дополнительные примечания</h3>
                    <p><%= inspection.notes %></p>
                </div>
            <% } %>
        </div>

        <div style="margin-top: 3rem; display: flex; justify-content: space-between; border-top: 1px solid #eee; padding-top: 2rem;">
            <div style="width: 40%; border-bottom: 1px solid #000; text-align: center;">
                <p>Подпись инспектора</p>
                <br><br>
                <p>(<%= inspection.inspector_name %>)</p>
            </div>
            <div style="width: 40%; border-bottom: 1px solid #000; text-align: center;">
                <p>М.П. Автосалона</p>
            </div>
        </div>
        
        <div style="margin-top: 2rem;" class="no-print">
            <a href="/inspections" class="btn btn-secondary">Назад к списку</a>
        </div>
    </div>
</div>

<style>
    @media print {
        .sidebar, .header, .no-print, .btn {
            display: none !important;
        }
        .main-content-wrapper {
            margin-left: 0 !important;
        }
        .card {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>

<%- include('../partials/footer') %>
