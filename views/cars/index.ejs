<%- include('../partials/header', { title: 'Автомобили', currentPage: 'cars', user: typeof user !== 'undefined' ? user : null }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>Управление автомобилями</h2>
            <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
            <a href="/cars/new" class="btn btn-primary">Добавить автомобиль</a>
            <% } %>
        </div>
        
        <% if (cars && cars.length > 0) { %>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Марка</th>
                            <th>Модель</th>
                            <th>Год</th>
                            <th>Цена (₽)</th>
                            <th>Цвет</th>
                            <th>Пробег (км)</th>
                            <th>Статус</th>
                            <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                            <th>Действия</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% cars.forEach(car => { %>
                            <tr>
                                <td><%= car.id %></td>
                                <td><strong><%= car.brand %></strong></td>
                                <td><%= car.model %></td>
                                <td><%= car.year %></td>
                                <td><%= car.price.toLocaleString('ru-RU') %></td>
                                <td><%= car.color || '-' %></td>
                                <td><%= car.mileage.toLocaleString('ru-RU') %></td>
                                <td>
                                    <span class="badge badge-<%= car.status === 'available' ? 'success' : 'warning' %>">
                                        <%= car.status === 'available' ? 'Доступен' : 'Продан' %>
                                    </span>
                                </td>
                                <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                                <td style="display: flex; gap: 0.5rem;">
                                    <a href="/cars/<%= car.id %>/edit" class="btn btn-sm btn-secondary">Редактировать</a>
                                    <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                                    <form method="POST" action="/cars/<%= car.id %>/delete" style="display: inline;" onsubmit="return confirm('Вы уверены, что хотите удалить этот автомобиль?');">
                                        <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                    </form>
                                    <% } %>
                                </td>
                                <% } %>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>Автомобили не найдены</p>
                <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                <a href="/cars/new" class="btn btn-primary">Добавить первый автомобиль</a>
                <% } %>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
