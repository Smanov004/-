<%- include('../partials/header', { title: 'Продажи', currentPage: 'sales', user: typeof user !== 'undefined' ? user : null }) %>

<div class="container">
    <div class="card">
        <div class="card-header">
            <h2>Управление продажами</h2>
            <a href="/sales/new" class="btn btn-primary">Оформить продажу</a>
        </div>
        
        <% if (sales && sales.length > 0) { %>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Автомобиль</th>
                            <th>Клиент</th>
                            <th>Телефон</th>
                            <th>Менеджер</th>
                            <th>Дата продажи</th>
                            <th>Цена (₽)</th>
                            <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                            <th>Действия</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% sales.forEach(sale => { %>
                            <tr>
                                <td><%= sale.id %></td>
                                <td>
                                    <strong><%= sale.car_name || 'Не указан' %></strong>
                                </td>
                                <td><%= sale.client_name || 'Не указан' %></td>
                                <td><%= sale.client_phone || '-' %></td>
                                <td><%= sale.manager_name || 'Не указан' %></td>
                                <td><%= new Date(sale.sale_date).toLocaleDateString('ru-RU') %></td>
                                <td><strong><%= parseFloat(sale.price).toLocaleString('ru-RU') %></strong></td>
                                <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                                <td>
                                    <form method="POST" action="/sales/<%= sale.id %>/delete" style="display: inline;" onsubmit="return confirm('Вы уверены, что хотите удалить эту продажу?');">
                                        <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                    </form>
                                </td>
                                <% } %>
                            </tr>
                        <% }); %>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="<%= typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor') ? 6 : 7 %>" style="text-align: right;"><strong>Итого:</strong></td>
                            <td><strong>
                                <%= sales.reduce((sum, sale) => sum + parseFloat(sale.price || 0), 0).toLocaleString('ru-RU') %> ₽
                            </strong></td>
                            <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'supervisor')) { %>
                            <td></td>
                            <% } %>
                        </tr>
                    </tfoot>
                </table>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>Продажи не найдены</p>
                <a href="/sales/new" class="btn btn-primary">Оформить первую продажу</a>
            </div>
        <% } %>
    </div>
</div>

<%- include('../partials/footer') %>
